# Engram MCP Server Configuration

# Data directory for SQLite databases
ENGRAM_DATA_DIR=./data

# Database filenames
ENGRAM_DB_FILENAME=engram.db
ENGRAM_VEC_DB_FILENAME=engram-vec.db

# Embedding provider: 'openai', 'local', or 'none'
# If OPENAI_API_KEY is set and provider is 'none', OpenAI is auto-detected
ENGRAM_EMBEDDING_PROVIDER=none

# OpenAI API key (enables semantic search)
# OPENAI_API_KEY=sk-...

# Custom OpenAI-compatible base URL (optional)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Namespace for memory isolation
ENGRAM_NAMESPACE=default

# Allowlist for per-request namespace override (comma-separated).
# Unset = any namespace accepted (multi-tenant free-for-all).
# When set, REST requests with unknown namespace return 400.
# ENGRAM_NAMESPACE_ALLOWLIST=default,work,personal

# Bounded LRU cache for per-namespace cores (prevents FD exhaustion).
# Each entry opens two SQLite handles.
ENGRAM_CORE_CACHE_SIZE=32

# Metric namespace allowlist — unknown namespaces collapse to "_other"
# to prevent Prometheus cardinality explosion.
# ENGRAM_METRIC_NAMESPACES=default,work,personal

# REST API auth — comma-separated tokens (unset = no auth)
# ENGRAM_API_TOKEN=secret1,secret2

# REST API rate limit (set to 'off' to disable)
ENGRAM_RATE_BURST=60
ENGRAM_RATE_PER_SEC=10
# ENGRAM_RATE_LIMIT=off

# Trust X-Forwarded-For header (only when running behind a real proxy).
# When off (default), the socket remote address identifies clients — safe for
# direct-to-internet deployment. When on, any client can rotate XFF to bypass
# rate limits, so ONLY enable when a trusted reverse proxy is in front.
# ENGRAM_TRUST_PROXY=1

# CORS origin for REST (default '*')
# ENGRAM_CORS_ORIGIN=https://myapp.example.com

# Logging
ENGRAM_LOG_LEVEL=info   # debug | info | warn | error
ENGRAM_LOG_FORMAT=json  # json | pretty
